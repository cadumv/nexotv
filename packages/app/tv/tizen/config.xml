<?xml version="1.0" encoding="UTF-8"?>
<!--
  Manifesto do app web Tizen (Samsung Smart TV). Empacotado em .wgt a partir do dist/.
  - access origin="*" + allow-navigation: libera o HTTP do provedor (sem CORS no runtime de TV).
  - profile name="tv" + screen-orientation landscape: comporta-se como app de TV.
  - O id/package abaixo é placeholder; ao assinar com seu certificado Samsung o
    Tizen Studio acerta o package id. Veja tv/BUILD_TV.md.
-->
<widget xmlns="http://www.w3.org/ns/widgets" xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://rajada.app/rajada" version="0.1.0" viewmodes="maximized">
  <tizen:application id="Rajada0001.Rajada" package="Rajada0001" required_version="6.0"/>
  <content src="index.html"/>
  <icon src="icon.png"/>
  <name>Rajada</name>
  <tizen:profile name="tv"/>
  <feature name="http://tizen.org/feature/screen.size.all"/>
  <tizen:setting screen-orientation="landscape" context-menu="disable"
                 background-support="disable" encryption="disable"
                 install-location="auto" hwkey-event="enable"/>
  <access origin="*" subdomains="true"/>
  <tizen:allow-navigation>*</tizen:allow-navigation>
  <tizen:privilege name="http://tizen.org/privilege/internet"/>
</widget>
